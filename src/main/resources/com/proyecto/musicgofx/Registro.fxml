<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Hyperlink?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="580.0" prefWidth="400.0"
            stylesheets="@styles.css"
            styleClass="registro-bg"
            xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.proyecto.musicgofx.controlador.RegistroController">
    <children>
        <VBox alignment="CENTER" spacing="18.0" prefWidth="340.0"
              AnchorPane.bottomAnchor="30.0" AnchorPane.leftAnchor="30.0"
              AnchorPane.rightAnchor="30.0" AnchorPane.topAnchor="30.0">
            <children>

                <Label text="Crear Cuenta" styleClass="registro-titulo">
                    <font>
                        <Font name="System Bold" size="36.0" />
                    </font>
                </Label>

                <Label text="Únete a MusicGO. Ingresa tus datos reales." styleClass="registro-subtitulo" />

                <VBox spacing="5.0">
                    <children>
                        <Label text="Elige tu Nombre de Usuario / Alias" styleClass="registro-label-campo" />
                        <TextField fx:id="txtUsuario" promptText="Ej. Juan99" styleClass="registro-textfield" />
                    </children>
                </VBox>

                <VBox spacing="5.0">
                    <children>
                        <Label text="Correo Electrónico (Gmail)" styleClass="registro-label-campo" />
                        <TextField fx:id="txtCorreo" promptText="tu_correo@gmail.com" styleClass="registro-textfield" />
                    </children>
                </VBox>

                <VBox spacing="5.0">
                    <children>
                        <Label text="Tu Edad (Requerido para control parental)" styleClass="registro-label-campo" />
                        <TextField fx:id="txtEdad" promptText="Ej. 21" styleClass="registro-textfield" />
                    </children>
                </VBox>

                <Label fx:id="lblMensaje" alignment="CENTER" prefWidth="300.0" wrapText="true" styleClass="registro-error" />

                <Button fx:id="btnRegistrar" mnemonicParsing="false" onAction="#procesarRegistro" prefWidth="340.0" text="Registrarse Ahora" styleClass="registro-btn-principal" />

                <Hyperlink onAction="#volverAlLogin" text="¿Ya tienes cuenta? Inicia sesión" styleClass="registro-link" />

            </children>
        </VBox>
    </children>
</AnchorPane>