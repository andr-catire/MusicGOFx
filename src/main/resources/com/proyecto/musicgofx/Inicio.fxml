<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.layout.VBox?>

<AnchorPane prefHeight="600.0" prefWidth="800.0" stylesheets="@styles.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.proyecto.musicgofx.controlador.InicioController">
    <children>
        <ScrollPane fx:id="inicioScrollPane" fitToWidth="true" styleClass="scroll-pane" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
            <content>
                <VBox fx:id="vboxContenedor" styleClass="padding-md">
                    <children>
                        <Label styleClass="section-header" text="Descubre tus Gustos" />
                        <Label styleClass="subsection-header" text="Canciones Disponibles" />

                        <FlowPane fx:id="flowPaneAudios" hgap="20.0" vgap="20.0">
                            <padding>
                                <Insets top="15.0" />
                            </padding>
                        </FlowPane>
                    </children>
                </VBox>
            </content>
        </ScrollPane>
    </children>
</AnchorPane>