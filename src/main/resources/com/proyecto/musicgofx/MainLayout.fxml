<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane prefHeight="700.0" prefWidth="1000.0" stylesheets="@styles.css" xmlns="http://javafx.com/javafx/25.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.proyecto.musicgofx.controlador.MainController">

   <left>
      <VBox fx:id="sideBar" prefWidth="240.0" spacing="10.0" styleClass="sidebar" BorderPane.alignment="CENTER">
         <children>
            <Label styleClass="logo-text" text="MusicGO" />

            <Button fx:id="btnInicio" maxWidth="1.7976931348623157E308" styleClass="nav-button" text="Inicio" />
            <Button fx:id="btnExplorar" maxWidth="1.7976931348623157E308" styleClass="nav-button" text="Explorar" />
            <Button fx:id="btnBiblioteca" maxWidth="1.7976931348623157E308" styleClass="nav-button" text="Biblioteca" />
            <Button fx:id="btnTienda" maxWidth="1.7976931348623157E308" styleClass="nav-button" text="Tienda" />

            <Button fx:id="btnAgregarAudio" maxWidth="1.7976931348623157E308" styleClass="nav-button" text="Agregar Audio" />
            <Button fx:id="btnAgregarProducto" maxWidth="1.7976931348623157E308" styleClass="nav-button" text="Agregar Producto" />
            <Button fx:id="btnListarUsuario" maxWidth="1.7976931348623157E308" styleClass="nav-button" text="Listar Usuarios" />

            <VBox VBox.vgrow="ALWAYS" />

            <Button fx:id="btnAjustes" maxWidth="1.7976931348623157E308" styleClass="nav-button" text="Ajustes" />
         </children>
         <padding>
            <Insets bottom="25.0" left="20.0" right="20.0" top="30.0" />
         </padding>
      </VBox>
   </left>

   <center>
      <VBox styleClass="main-center" BorderPane.alignment="CENTER">
         <children>
            <HBox alignment="CENTER_LEFT" prefHeight="60.0" spacing="15.0">
               <padding>
                  <Insets bottom="10.0" left="20.0" right="30.0" top="15.0" />
               </padding>
               <children>
                  <TextField  fx:id="txtBuscadorTop" prefWidth="350.0" promptText="Explora el mundo de la música..." styleClass="text-field" />

                  <Region HBox.hgrow="ALWAYS" />

                  <Button fx:id="btnPerfilUsuario" mnemonicParsing="false" styleClass="button" text="👤 Perfil" />

                  <Button fx:id="btnBilletera" mnemonicParsing="false" styleClass="button" text="💳 Billetera" />
               </children>
            </HBox>

            <AnchorPane fx:id="contenedorCentral" VBox.vgrow="ALWAYS" />
         </children>
      </VBox>
   </center>

   <bottom>
      <HBox alignment="CENTER" styleClass="player-bar" BorderPane.alignment="CENTER">
         <children>
            <VBox alignment="CENTER_LEFT" prefWidth="250.0" spacing="2.0">
               <children>
                  <Label fx:id="lblTituloAudio" styleClass="player-title" text="Título de la Canción" />
                  <Label fx:id="lblArtistaAudio" styleClass="player-artist" text="Artista" />
               </children>
            </VBox>
            <HBox alignment="CENTER" spacing="20.0" HBox.hgrow="ALWAYS">
               <children>
                  <Button fx:id="btnAnterior" mnemonicParsing="false" styleClass="player-button" text="⏮" />
                  <Button fx:id="btnPlay" mnemonicParsing="false" styleClass="player-button-play" text="▶" />
                  <Button fx:id="btnSiguiente" mnemonicParsing="false" styleClass="player-button" text="⏭" />
               </children>
            </HBox>
            <HBox alignment="CENTER_RIGHT" prefWidth="250.0" />
         </children>
      </HBox>
   </bottom>

</BorderPane>
