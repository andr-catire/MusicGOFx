<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Hyperlink?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="550.0" prefWidth="400.0"
            stylesheets="@styles.css"
            styleClass="login-bg"
            xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.proyecto.musicgofx.controlador.LoginController">

    <children>
        <VBox alignment="CENTER" spacing="18.0" prefWidth="340.0"
              AnchorPane.bottomAnchor="40.0" AnchorPane.leftAnchor="30.0"
              AnchorPane.rightAnchor="30.0" AnchorPane.topAnchor="40.0">
            <children>

                <Label text="MusicGO" styleClass="login-titulo">
                    <font>
                        <Font name="System Bold" size="42.0" />
                    </font>
                    <VBox.margin>
                        <Insets bottom="10.0" />
                    </VBox.margin>
                </Label>

                <Label text="Tu música, tus reglas. Inicia sesión para continuar." styleClass="login-subtitulo" />

                <VBox spacing="5.0">
                    <children>
                        <Label text="Nombre de Usuario o Alias" styleClass="login-label-campo" />
                        <TextField fx:id="txtUsuario" promptText="Ej. Andrés123" styleClass="login-textfield" />
                    </children>
                </VBox>

                <VBox spacing="5.0">
                    <children>
                        <Label text="Correo Electrónico (Gmail)" styleClass="login-label-campo" />
                        <TextField fx:id="txtCorreo" promptText="usuario@gmail.com" styleClass="login-textfield" />
                    </children>
                </VBox>

                <VBox fx:id="vboxEdad" spacing="5.0" visible="false" managed="false">
                    <children>
                        <Label text="Tu Edad" styleClass="login-label-campo" />
                        <TextField fx:id="txtEdad" promptText="Ej. 18" styleClass="login-textfield" />
                    </children>
                </VBox>

                <Label fx:id="lblMensaje" alignment="CENTER" prefWidth="300.0" wrapText="true" styleClass="login-error" />

                <Button fx:id="btnAccion" mnemonicParsing="false" onAction="#manejarBotonPrincipal" prefWidth="340.0" text="Iniciar Sesión" styleClass="login-btn-principal">
                    <VBox.margin>
                        <Insets top="10.0" />
                    </VBox.margin>
                </Button>

                <Hyperlink fx:id="linkRegistro" onAction="#irAPantallaRegistro" text="¿No tienes cuenta? Regístrate aquí" styleClass="login-link" />

            </children>
        </VBox>
    </children>
</AnchorPane>