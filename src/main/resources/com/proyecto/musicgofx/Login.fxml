<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Hyperlink?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="550.0" prefWidth="400.0"
            style="-fx-background-color: #0b0b0e;"
            xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.proyecto.musicgofx.controlador.LoginController">

    <children>
        <VBox alignment="CENTER" spacing="18.0" prefWidth="340.0"
              AnchorPane.bottomAnchor="40.0" AnchorPane.leftAnchor="30.0"
              AnchorPane.rightAnchor="30.0" AnchorPane.topAnchor="40.0">
            <children>

                <Label text="MusicGO"
                       style="-fx-text-fill: linear-gradient(to right, #8a2be2, #4a90e2); -fx-font-weight: bold;">
                    <font>
                        <Font name="System Bold" size="42.0" />
                    </font>
                    <VBox.margin>
                        <Insets bottom="10.0" />
                    </VBox.margin>
                </Label>

                <Label text="Tu música, tus reglas. Inicia sesión para continuar."
                       style="-fx-text-fill: #7f8c8d; -fx-font-size: 13px;" />

                <VBox spacing="5.0">
                    <children>
                        <Label text="Nombre de Usuario o Alias" style="-fx-text-fill: #b3b3b3; -fx-font-size: 12px; -fx-font-weight: bold;" />
                        <TextField fx:id="txtUsuario" promptText="Ej. Andrés123"
                                   style="-fx-background-color: #1e1e24; -fx-text-fill: #ffffff; -fx-background-radius: 8; -fx-padding: 12; -fx-prompt-text-fill: #555555; -fx-border-color: #2a2a35; -fx-border-radius: 8;" />
                    </children>
                </VBox>

                <VBox spacing="5.0">
                    <children>
                        <Label text="Correo Electrónico (Gmail)" style="-fx-text-fill: #b3b3b3; -fx-font-size: 12px; -fx-font-weight: bold;" />
                        <TextField fx:id="txtCorreo" promptText="usuario@gmail.com"
                                   style="-fx-background-color: #1e1e24; -fx-text-fill: #ffffff; -fx-background-radius: 8; -fx-padding: 12; -fx-prompt-text-fill: #555555; -fx-border-color: #2a2a35; -fx-border-radius: 8;" />
                    </children>
                </VBox>

                <VBox fx:id="vboxEdad" spacing="5.0" visible="false" managed="false">
                    <children>
                        <Label text="Tu Edad" style="-fx-text-fill: #b3b3b3; -fx-font-size: 12px; -fx-font-weight: bold;" />
                        <TextField fx:id="txtEdad" promptText="Ej. 18"
                                   style="-fx-background-color: #1e1e24; -fx-text-fill: #ffffff; -fx-background-radius: 8; -fx-padding: 12; -fx-prompt-text-fill: #555555; -fx-border-color: #2a2a35; -fx-border-radius: 8;" />
                    </children>
                </VBox>

                <Label fx:id="lblMensaje" alignment="CENTER" prefWidth="300.0" wrapText="true"
                       style="-fx-text-fill: #e74c3c; -fx-font-size: 12px; -fx-font-weight: bold;" />

                <Button fx:id="btnAccion" mnemonicParsing="false" onAction="#manejarBotonPrincipal" prefWidth="340.0" text="Iniciar Sesión"
                        style="-fx-background-color: linear-gradient(to right, #7b2cbf, #3f37c9); -fx-text-fill: #ffffff; -fx-background-radius: 25; -fx-padding: 12; -fx-font-size: 14px; -fx-font-weight: bold; -fx-cursor: hand;">
                    <VBox.margin>
                        <Insets top="10.0" />
                    </VBox.margin>
                </Button>

                <Hyperlink fx:id="linkRegistro" onAction="#irAPantallaRegistro" text="¿No tienes cuenta? Regístrate aquí"
                           style="-fx-text-fill: #4a90e2; -fx-font-size: 12px;" />

            </children>
        </VBox>
    </children>
</AnchorPane>