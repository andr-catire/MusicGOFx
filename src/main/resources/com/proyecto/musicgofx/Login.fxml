<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Hyperlink?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.VBox?>

<AnchorPane prefHeight="550.0" prefWidth="400.0" styleClass="login-bg" stylesheets="@styles.css" xmlns="http://javafx.com/javafx/25.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.proyecto.musicgofx.controlador.LoginController">
    <children>
        <VBox alignment="CENTER" spacing="15.0" AnchorPane.bottomAnchor="40.0" AnchorPane.leftAnchor="40.0" AnchorPane.rightAnchor="40.0" AnchorPane.topAnchor="40.0">
            <children>

                <Label styleClass="login-titulo" text="MusicGO" />
                <Label styleClass="login-subtitulo" text="Inicia sesión para continuar" />

                <VBox spacing="5.0">
                    <children>
                        <Label styleClass="login-label-campo" text="Nombre de Usuario" />
                        <TextField fx:id="txtUsuario" promptText="Ingresa tu usuario" styleClass="login-textfield" />
                    </children>
                    <VBox.margin>
                        <Insets top="15.0" />
                    </VBox.margin>
                </VBox>

                <VBox spacing="5.0">
                    <children>
                        <Label styleClass="login-label-campo" text="Correo Electrónico (Gmail)" />
                        <TextField fx:id="txtCorreo" promptText="tu_correo@gmail.com" styleClass="login-textfield" />
                    </children>
                </VBox>

                <Label fx:id="lblMensaje" styleClass="login-error" text="" />

                <Button fx:id="btnAccion" maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#manejarBotonPrincipal" styleClass="login-btn-principal" text="Iniciar Sesión">
                    <VBox.margin>
                        <Insets top="10.0" />
                    </VBox.margin>
                </Button>

                <Hyperlink fx:id="linkRegistro" onAction="#irAPantallaRegistro" styleClass="login-link" text="¿No tienes cuenta? Regístrate aquí">
                    <VBox.margin>
                        <Insets top="15.0" />
                    </VBox.margin>
                </Hyperlink>

            </children>
        </VBox>
    </children>
</AnchorPane>
