<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<AnchorPane prefHeight="600.0" prefWidth="800.0" stylesheets="@styles.css" xmlns="http://javafx.com/javafx/22" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.proyecto.musicgofx.controlador.verContenidoPlaylistController">
    <children>
        <VBox spacing="20.0" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
            <padding>
                <Insets bottom="20.0" left="25.0" right="25.0" top="20.0" />
            </padding>
            <children>
                <Button mnemonicParsing="false" onAction="#volverABiblioteca" styleClass="button, secundario" style="-fx-border-color: transparent; -fx-padding: 0; -fx-font-weight: bold; -fx-font-size: 14px;" text="← Volver a Tu Biblioteca" />

                <HBox alignment="BOTTOM_LEFT" spacing="25.0">
                    <children>
                        <VBox alignment="CENTER_LEFT" spacing="10.0" HBox.hgrow="ALWAYS">
                            <children>
                                <Label text="PLAYLIST" styleClass="label-muted" style="-fx-font-weight: bold; -fx-font-size: 12px;" />
                                <Label fx:id="lblTituloPlaylist" text="Cargando..." styleClass="label" style="-fx-font-weight: bold; -fx-font-size: 48px;" />
                                <Label fx:id="lblDuracion" text="0 canciones" styleClass="label-muted" style="-fx-font-size: 14px;" />

                                <HBox alignment="CENTER_LEFT" spacing="15.0">
                                    <children>
                                        <Button mnemonicParsing="false" onAction="#reproducirPlaylist" styleClass="button" text="▶ Reproducir" />
                                        <Button mnemonicParsing="false" onAction="#agregarCancion" styleClass="button, secundario" text="Añadir Canción" />
                                        <Button mnemonicParsing="false" onAction="#eliminarPlaylist" styleClass="button, secundario" style="-fx-text-fill: #e91429; -fx-border-color: rgba(233, 20, 41, 0.4);" text="🗑 Eliminar" />
                                    </children>
                                    <VBox.margin>
                                        <Insets top="10.0" />
                                    </VBox.margin>
                                </HBox>
                            </children>
                        </VBox>
                    </children>
                </HBox>

                <Separator prefWidth="200.0" style="-fx-opacity: 0.2;" />

                <ScrollPane fitToWidth="true" style="-fx-background-color: transparent; -fx-background-insets: 0; -fx-padding: 0;" VBox.vgrow="ALWAYS">
                    <content>
                        <VBox fx:id="vboxListaCanciones" spacing="8.0" style="-fx-background-color: transparent;">
                            <padding>
                                <Insets bottom="10.0" left="5.0" right="5.0" top="10.0" />
                            </padding>
                        </VBox>
                    </content>
                </ScrollPane>
            </children>
        </VBox>
    </children>
</AnchorPane>